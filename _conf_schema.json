{
  "character_name": {
    "description": "角色名称，用于帮助信息显示",
    "type": "string",
    "default": "头条flag"
  },
  "asset_base_url": {
    "description": "图片仓库的raw基地址，如 https://raw.githubusercontent.com/用户/仓库/main",
    "type": "string",
    "default": "https://raw.githubusercontent.com/204343414/astrbot_plugin_mouthpiece/master"
  },
  "font_path": {
    "description": "字体文件路径（相对于插件目录）",
    "type": "string",
    "default": "https://raw.githubusercontent.com/lxgw/LxgwWenKai/main/fonts/TTF/LXGWWenKai-Regular.ttf"
  },
    "text_left_top": {
    "description": "文字区域左上角坐标，格式: x,y 例如 167,762",
    "type": "string",
    "default": "161,755"
  },
  "text_right_bottom": {
    "description": "文字区域右下角坐标，格式: x,y 例如 500,900",
    "type": "string",
    "default": "743,1112"
  },
  "text_color_r": {
    "description": "文字颜色R(0-255)",
    "type": "int",
    "default": 0
  },
  "text_color_g": {
    "description": "文字颜色G(0-255)",
    "type": "int",
    "default": 0
  },
  "text_color_b": {
    "description": "文字颜色B(0-255)",
    "type": "int",
    "default": 0
  },
  "ai_tool_enabled": {
    "description": "是否启用AI自动举牌工具",
    "type": "bool",
    "default": true
  },
  "auto_enabled": {
  "description": "是否启用概率嘴替（对 Bot 的普通回复生效）",
  "type": "bool",
  "default": false
  },
"auto_probability": {
  "description": "嘴替触发概率（0-100）",
  "type": "int",
  "default": 10
}







