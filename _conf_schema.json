{
  "character_name": {
    "description": "角色名称，用于帮助信息显示",
    "type": "string",
    "default": "小叶子"
  },
  "asset_base_url": {
    "description": "图片仓库的raw基地址，如 https://raw.githubusercontent.com/用户/仓库/main",
    "type": "string",
    "default": "https://raw.githubusercontent.com/204343414/mouthpiece-assets/main"
  },
  "font_path": {
    "description": "字体文件路径（相对于插件目录）",
    "type": "string",
    "default": "assets/fonts/5_Minecraft AE(支持中文).ttf"
  },
  "text_region": {
    "description": "文字绘制区域",
    "type": "object",
    "items": {
      "x": {
        "description": "左上角X",
        "type": "int",
        "default": 100
      },
      "y": {
        "description": "左上角Y",
        "type": "int",
        "default": 432
      },
      "w": {
        "description": "宽度",
        "type": "int",
        "default": 319
      },
      "h": {
        "description": "高度",
        "type": "int",
        "default": 204
      }
    }
  },
  "text_color_r": {
    "description": "文字颜色R(0-255)",
    "type": "int",
    "default": 0
  },
  "text_color_g": {
    "description": "文字颜色G(0-255)",
    "type": "int",
    "default": 0
  },
  "text_color_b": {
    "description": "文字颜色B(0-255)",
    "type": "int",
    "default": 0
  },
  "ai_tool_enabled": {
    "description": "是否启用AI自动举牌工具",
    "type": "bool",
    "default": true
  }
}

